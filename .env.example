# Copy to .env and fill in. .env is gitignored.

# Clustering (uses the trained MODEL_DIR encoder)
N_CLUSTERS=3
RANDOM_STATE=94

# Directories of .log or .json log files
DATA_DIR=data/train
TEST_DATA_DIR=data/test

# Base model to fine-tune
BASE_MODEL=answerdotai/ModernBERT-base

# Where checkpoints are written
OUTPUT_DIR=models

# Where evaluation reports go
LOGGING_DIR=logs
TENSORBOARD_LOGGING_DIR=logs

# Fine-tuned model used by the API and `evaluate`; update after each run
MODEL_DIR=models/answerdotai/ModernBERT-base/log_classifier_model_weighted_ce

# Where inference outputs go (clusterer reports/plots, batch eval exports)
INFERENCE_OUTPUT_DIR=output

# API host/port
PORT="8000"
HOST="127.0.0.1"

# Drain3 template miner
DRAIN3_STATE_FILE=data/drain3_state.bin
DRAIN3_TRAIN_DIR=data/train
DRAIN3_TEST_DIR=data/test

# Anomaly scoring tuning (optional)
# ANOMALY_SCORE_THRESHOLD=20.0
# ANOMALY_UNDER_PREDICTION_WEIGHT=1.5
# ANOMALY_OVER_PREDICTION_WEIGHT=1.0
# ANOMALY_CALIBRATION_PERCENTILE=95.0
